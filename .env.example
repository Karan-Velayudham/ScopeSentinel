OPENAI_API_KEY="your_openai_api_key_here"

# Jira credentials
# Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL="https://your-org.atlassian.net"
JIRA_USERNAME="your-email@example.com"
JIRA_API_TOKEN="your_jira_api_token_here"

# GitHub credentials
# Create a token with repo + pull_request scopes at: https://github.com/settings/tokens
GITHUB_TOKEN="your_github_personal_access_token_here"
GITHUB_REPO_OWNER="your-github-username-or-org"
GITHUB_REPO_NAME="your-target-repo-name"
# Absolute path to a local clone of the GitHub repo above
GITHUB_REPO_LOCAL_PATH="/absolute/path/to/local/clone/of/repo"

