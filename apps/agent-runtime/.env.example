# =============================================================================
# ScopeSentinel — Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# =============================================================================

# --- LLM ---
# Your OpenAI API key (required unless using Ollama locally)
OPENAI_API_KEY="your_openai_api_key_here"

# --- Logging ---
# LOG_FORMAT: "console" (human-readable, dev default) | "json" (structured, CI/prod)
LOG_FORMAT="console"
# LOG_LEVEL: debug | info | warning | error  (default: info)
LOG_LEVEL="info"

# --- Jira ---
# Base URL of your Atlassian instance (no trailing slash)
JIRA_URL="https://your-org.atlassian.net"
# Email address associated with your Jira account
JIRA_USERNAME="your-email@example.com"
# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN="your_jira_api_token_here"

# --- GitHub ---
# Personal access token with repo + pull_request scopes
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN="your_github_personal_access_token_here"
# GitHub username or organisation that owns the target repo
GITHUB_REPO_OWNER="your-github-username-or-org"
# Name of the target repository (just the repo name, not the full URL)
GITHUB_REPO_NAME="your-target-repo-name"
# Absolute path to a local clone of GITHUB_REPO_OWNER/GITHUB_REPO_NAME
GITHUB_REPO_LOCAL_PATH="/absolute/path/to/local/clone/of/repo"
