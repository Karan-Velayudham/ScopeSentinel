# =============================================================================
# ScopeSentinel API — Environment Variables (Phase 1)
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# =============================================================================

# --- Logging ---
# LOG_FORMAT: "console" (human-readable, dev) | "json" (structured, prod)
LOG_FORMAT="console"
LOG_LEVEL="info"

# --- Database (PostgreSQL) ---
# Default values match the docker-compose setup
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="sentinel"
DB_PASSWORD="sentinel_dev"
DB_NAME="scopesentinel"
DB_ECHO="false"

# --- Broker (Redis) ---
REDIS_URL="redis://localhost:6379/0"

# --- CORS ---
# Comma-separated list of allowed origins. Use * in development.
ALLOWED_ORIGINS="*"

# --- Seeding ---
# Default initial admin config. OVERRIDE ADMIN_API_KEY IN PROD!
ADMIN_EMAIL="admin@scopesentinel.local"
ADMIN_API_KEY="dev-admin-api-key-1"

# --- Auth ---
AUTH_SECRET="b65476a6d68b6a6d68b6a6d68b6a6d68"
